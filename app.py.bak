@keyframes rise{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.mav{width:30px;height:30px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:3px}
.mav.ai{background:linear-gradient(135deg,#4a78f5,#8b5cf6,#d4a843);color:#fff;
  font-family:'Fraunces',serif;font-size:.83rem;font-weight:500;
