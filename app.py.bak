@app.post("/stream2")
async def stream_chat2(req: Request):
    data = await req.json()
    msg = data.get("message", "").strip()
    hist = data.get("history", [])
    if not msg:
        return JSONResponse({"error": "empty"}, status_code=400)
    msgs = [{"role": "system", "content": "You are a helpful assistant."}, {"role": "user", "content": msg}]
    async def _gen():
        yield '{"skill": "general", "mode": "easy"}\n'
        result = groq_generate(msgs, max_tokens=1000, model="groq/compound")
        words = result.split(' ')
        buf = ''
        for i, w in enumerate(words):
            buf += w + ' '
            if len(buf) >= 8 or i == len(words) - 1:
                yield buf
                buf = ''
    return StreamingResponse(_gen(), media_type="text/plain", headers={"X-Accel-Buffering": "no", "Cache-Control": "no-cache"})

# Patch system prompt to inject Claude-style personality
_CLAUDE_PERSONALITY = """
<personality>
Communicate with intellectual curiosity and genuine warmth. Be direct and confident but never dismissive.
Push back respectfully when something seems wrong — do not capitulate just because a user insists.
Use concrete examples and analogies to explain complex ideas. Avoid filler phrases like "Certainly!", "Of course!", "Absolutely!", "Great!", "Sure!" at the start of responses.
Never be sycophantic. Prioritize honesty over validation.
Match the user's tone — casual for casual, technical for technical.
Acknowledge uncertainty openly rather than projecting false confidence.
</personality>
"""
SYSTEM_PROMPT = SYSTEM_PROMPT.replace("</eliteomni_behavior>", _CLAUDE_PERSONALITY + "\n</eliteomni_behavior>")
