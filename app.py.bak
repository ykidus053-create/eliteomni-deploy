def _audit(event: str, data: dict):
    try:
        import json as _aj, datetime as _dt
        record = {"ts": _dt.datetime.utcnow().isoformat(), "event": event, **data}
        with open(_AUDIT_LOG_PATH, "a") as _af:
            _af.write(_aj.dumps(record) + "\n")
    except Exception:
        pass

