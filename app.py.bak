  box-shadow:0 0 20px rgba(74,120,245,.35),0 2px 8px rgba(0,0,0,.4);
  animation:gemPulse 4s ease-in-out infinite}
@keyframes gemPulse{0%,100%{box-shadow:0 0 20px rgba(74,120,245,.35),0 2px 8px rgba(0,0,0,.4)}50%{box-shadow:0 0 30px rgba(139,92,246,.5),0 2px 8px rgba(0,0,0,.4)}}
.logo-name{font-family:'Fraunces',serif;font-size:1.08rem;font-weight:500;color:var(--t1);letter-spacing:-.01em}
.logo-v{font-size:.56rem;color:var(--t3);margin-left:5px;font-family:'DM Mono',monospace;
  background:var(--g2);border:1px solid var(--bd);padding:1px 5px;border-radius:4px}
.new-btn{width:100%;padding:8px 12px;border-radius:10px;
  background:linear-gradient(135deg,rgba(74,120,245,.12),rgba(139,92,246,.08));
  border:1px solid rgba(74,120,245,.2);color:var(--t2);font-size:.75rem;
  font-family:'DM Sans',sans-serif;cursor:pointer;display:flex;align-items:center;gap:8px;
  transition:all .18s;position:relative;overflow:hidden}
.new-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(74,120,245,.15),rgba(139,92,246,.1));opacity:0;transition:opacity .18s}
.new-btn:hover::before{opacity:1}
.new-btn:hover{border-color:rgba(74,120,245,.4);color:var(--t1);transform:translateY(-1px);box-shadow:0 4px 16px rgba(74,120,245,.15)}
.sb-scroll{flex:1;overflow-y:auto;padding:10px 8px}
.sb-scroll::-webkit-scrollbar{width:2px}
.sb-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px}
