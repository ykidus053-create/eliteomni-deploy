_TASK_DB = os.path.expanduser("~/eliteomni_tasks.db")
def _init_task_db():
    import sqlite3 as _tdb
    con = _tdb.connect(_TASK_DB)
    con.execute("""CREATE TABLE IF NOT EXISTS tasks (
