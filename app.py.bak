]

HTML = r"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>EliteOmni v16</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10.6.1/dist/mermaid.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark-dimmed.min.css">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}html,body{height:100%;overflow:hidden}
:root{
  --bg:#060810;--g1:rgba(255,255,255,.028);--g2:rgba(255,255,255,.05);--g3:rgba(255,255,255,.08);
  --bd:rgba(255,255,255,.06);--bd2:rgba(255,255,255,.11);--bd3:rgba(255,255,255,.18);
  --t1:#eef2ff;--t2:rgba(190,210,255,.58);--t3:rgba(180,200,255,.3);--t4:rgba(180,200,255,.15);
  --gold:#d4a843;--teal:#19c4a8;--red:#e05555;--green:#27c47a;--blue:#4a78f5;--purple:#8b5cf6;
  --sb:272px;
  --glow-blue:rgba(74,120,245,.18);--glow-gold:rgba(212,168,67,.12);
  --radius:16px;--radius-sm:10px;--radius-xs:7px;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);letter-spacing:.01em}

/* ── ANIMATED BACKGROUND MESH ── */
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 1100px 700px at 8% 5%,rgba(74,120,245,.07) 0%,transparent 65%),
    radial-gradient(ellipse 800px 600px at 92% 95%,rgba(212,168,67,.055) 0%,transparent 60%),
    radial-gradient(ellipse 600px 400px at 50% 50%,rgba(139,92,246,.035) 0%,transparent 70%);
  animation:meshShift 18s ease-in-out infinite alternate;}
@keyframes meshShift{0%{opacity:1}50%{opacity:.7}100%{opacity:1}}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.012'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");}
#shell{position:relative;z-index:1;display:flex;height:100dvh}
#loader{position:fixed;top:0;left:0;right:0;z-index:200;padding:9px 20px;background:rgba(79,126,247,.12);border-bottom:1px solid rgba(79,126,247,.28);font-size:.76rem;color:#7aaeff;display:none;align-items:center;gap:10px;justify-content:center;backdrop-filter:blur(12px)}
#loader.show{display:none}
.ldot{width:6px;height:6px;border-radius:50%;background:#7aaeff;animation:ldp 1.2s infinite}
@keyframes ldp{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.7)}}
.lbar-w{width:140px;height:2px;background:rgba(79,126,247,.2);border-radius:2px;overflow:hidden}
.lbar{height:100%;background:linear-gradient(90deg,var(--blue),var(--gold));border-radius:2px;animation:lsp 2s infinite}
@keyframes lsp{0%{width:0%;margin-left:0}50%{width:60%;margin-left:20%}100%{width:0%;margin-left:100%}}
#sb{width:var(--sb);flex-shrink:0;display:flex;flex-direction:column;
  background:rgba(6,8,16,.92);border-right:1px solid var(--bd);
  backdrop-filter:blur(32px) saturate(180%);
  transition:width .28s cubic-bezier(.4,0,.2,1),opacity .28s;overflow:hidden;
  box-shadow:1px 0 0 rgba(255,255,255,.03),4px 0 32px rgba(0,0,0,.4)}
#sb.off{width:0;opacity:0;pointer-events:none}
.sb-top{padding:18px 14px 14px;border-bottom:1px solid var(--bd);flex-shrink:0}
.logo{display:flex;align-items:center;gap:11px;margin-bottom:16px}
.logo-gem{width:32px;height:32px;border-radius:10px;flex-shrink:0;
  background:linear-gradient(135deg,#4a78f5 0%,#8b5cf6 50%,#d4a843 100%);
