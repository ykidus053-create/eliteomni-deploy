.hi{padding:8px 10px;border-radius:9px;font-size:.74rem;color:var(--t3);cursor:pointer;
  border:1px solid transparent;transition:all .15s;margin-bottom:2px;
  display:flex;align-items:center;justify-content:space-between;gap:4px}
.hi-title{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hi-del{flex-shrink:0;opacity:0;font-size:.65rem;color:var(--t3);background:none;border:none;cursor:pointer;padding:2px 4px;border-radius:4px;transition:all .13s}
.hi:hover .hi-del{opacity:1}.hi-del:hover{color:var(--red);background:rgba(224,85,85,.1)}
.hi:hover{background:var(--g2);border-color:var(--bd);color:var(--t2)}
.hi.on{background:rgba(74,120,245,.1);border-color:rgba(74,120,245,.2);color:var(--t1)}
.sb-bot{padding:10px 8px;border-top:1px solid var(--bd);flex-shrink:0}
.urow{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:10px;
  background:var(--g1);border:1px solid var(--bd);transition:all .15s}
