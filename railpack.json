{
  "provider": "python",
  "steps": {
    "install": {
      "commands": [
        "python -m venv /app/.venv",
        { "path": "/app/.venv/bin" },
        { "src": "requirements.txt", "dest": "requirements.txt" },
        "pip install -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "cmd": "/app/.venv/bin/python -m uvicorn app:app --host 0.0.0.0 --port $PORT"
  }
}
