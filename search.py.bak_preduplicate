    # Explicit SEARCH() calls get a single targeted fallback
    if explicit_queries:
        for q in explicit_queries[:2]:
            result = tool_search(q.strip())
            if result:
                context = f"\n[WEB SEARCH RESULTS]\n{result[:800]}\n[END SEARCH RESULTS]\n"
