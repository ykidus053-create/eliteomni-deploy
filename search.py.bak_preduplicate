    # SearXNG up but no results — tell model to use knowledge
    if _searxng_healthy:
        return clean_msg, "\n[WEB SEARCH: No results found. Answer from your knowledge.]\n"

    # SearXNG down — inject nothing; model answers naturally without disclaimers
